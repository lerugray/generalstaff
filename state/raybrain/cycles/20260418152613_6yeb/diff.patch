+"""Phase 1 plumbing tests for raybrain.eval — stub scorer; no LLM judge."""
+from __future__ import annotations
+
+from pathlib import Path
+
+import pytest
+
+from raybrain.eval.ragas_runner import EvalReport, GoldenSetError, load_golden_set, run_eval
+from raybrain.eval.report import render_report
+
+GOLDEN = """\
+- query: "asymmetric objectives"
+  expected_sources: [{corpus_path: "a.md", lines: [45, 78]}]
+- query: "BGA interface design"
+  expected_sources: [{corpus_path: "b.md", lines: [20, 40]}]
+"""
+
+
+def _golden(tmp_path: Path, body: str = GOLDEN) -> Path:
+    p = tmp_path / "queries.yaml"
+    p.write_text(body, encoding="utf-8")
+    return p
+
+
+def _retrieval(query):
+    return [{"corpus_path": "stub.md", "text": query}]
+
+
+def _scorer(query, retrieved, expected):
+    return {"context_precision": float(bool(retrieved)),
+            "context_recall": float(bool(retrieved and expected))}
+
+
+def test_load_golden_set_valid_and_empty(tmp_path: Path) -> None:
+    assert len(load_golden_set(_golden(tmp_path))) == 2
+    empty = tmp_path / "e.yaml"
+    empty.write_text("", encoding="utf-8")
+    assert load_golden_set(empty) == []
+
+
+def test_load_golden_set_missing_raises(tmp_path: Path) -> None:
+    with pytest.raises(GoldenSetError, match="not found"):
+        load_golden_set(tmp_path / "nope.yaml")
+
+
+def test_load_golden_set_rejects_bad_shape(tmp_path: Path) -> None:
+    p = tmp_path / "bad.yaml"
+    p.write_text("- expected_sources: []\n", encoding="utf-8")
+    with pytest.raises(GoldenSetError, match="query"):
+        load_golden_set(p)
+    p.write_text("query: solo\n", encoding="utf-8")
+    with pytest.raises(GoldenSetError, match="list"):
+        load_golden_set(p)
+
+
+def test_run_eval_aggregates_per_query_and_mean(tmp_path: Path) -> None:
+    seen: list[str] = []
+
+    def retrieval(q: str):
+        seen.append(q)
+        return _retrieval(q)
+
+    report = run_eval(_golden(tmp_path), retrieval, scorer=_scorer)
+    assert isinstance(report, EvalReport)
+    assert len(seen) == 2 and len(report.per_query) == 2
+    assert report.mean_scores == {"context_precision": 1.0, "context_recall": 1.0}
+
+
+def test_run_eval_mean_averages_across_queries(tmp_path: Path) -> None:
+    def varying(query, retrieved, expected):
+        return {"context_recall": 1.0 if "asymmetric" in query else 0.0}
+
+    assert run_eval(_golden(tmp_path), _retrieval, scorer=varying).mean_scores[
+        "context_recall"
+    ] == pytest.approx(0.5)
+
+
+def test_render_report_writes_markdown(tmp_path: Path) -> None:
+    report = run_eval(_golden(tmp_path), _retrieval, scorer=_scorer)
+    out = tmp_path / "r.md"
+    text = render_report(report, out_path=out)
+    assert "# raybrain eval report" in text and "context_recall" in text
+    assert out.read_text(encoding="utf-8") == text
