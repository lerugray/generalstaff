diff --git a/src/raybrain/cli.py b/src/raybrain/cli.py
new file mode 100644
index 0000000..7368303
--- /dev/null
+++ b/src/raybrain/cli.py
@@ -0,0 +1,30 @@
+from __future__ import annotations
+
+import typer
+
+from raybrain import __version__
+
+app = typer.Typer(add_completion=False, help="raybrain — retrieval-only second brain.")
+
+
+def _version_callback(value: bool) -> None:
+    if value:
+        typer.echo(f"raybrain {__version__}")
+        raise typer.Exit(code=0)
+
+
+@app.callback(invoke_without_command=True)
+def main(
+    version: bool = typer.Option(
+        False,
+        "--version",
+        callback=_version_callback,
+        is_eager=True,
+        help="Show version and exit.",
+    ),
+) -> None:
+    return None
+
+
+if __name__ == "__main__":
+    app()
