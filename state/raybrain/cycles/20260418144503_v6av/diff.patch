+[project]
+name = "raybrain"
+version = "0.0.1"
+description = "Retrieval-only second-brain plugin (Karpathy LLM-Wiki layer 3)."
+requires-python = ">=3.12,<3.13"
+dependencies = [
+    "typer>=0.12",
+    "pydantic>=2",
+    "llama-index-core>=0.11",
+    "llama-index-readers-file>=0.2",
+    "python-frontmatter>=1.1",
+    "ragas>=0.2",
+]
+
+[project.scripts]
+raybrain = "raybrain.cli:app"
+
+[build-system]
+requires = ["hatchling"]
+build-backend = "hatchling.build"
+
+[tool.hatch.build.targets.wheel]
+packages = ["src/raybrain"]
+
+[dependency-groups]
+dev = [
+    "ruff>=0.6",
+    "pytest>=8",
+]
+
+[tool.ruff]
+line-length = 100
+target-version = "py312"
+src = ["src", "tests"]
+
+[tool.ruff.lint]
+select = ["E", "F", "I", "W", "UP"]
+
+[tool.pytest.ini_options]
+testpaths = ["tests"]
+addopts = "-ra"
