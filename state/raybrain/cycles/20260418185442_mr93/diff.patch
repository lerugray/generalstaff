+"""Privacy guards — network egress + filesystem containment.
+
+Mechanical encoding of the privacy rules described in CLAUDE.md §5
+("Policy surface"). Callers invoke these guards before any network
+call or filesystem read that involves user-supplied paths.
+
+- `network_guard.assert_local` rejects any URL whose host is not
+  localhost (or explicitly allowlisted). This backstops the
+  "local-only LLM" posture of the ingest layer.
+- `path_guard.assert_under_corpus` rejects any path that resolves
+  outside the corpus root. This backstops the "user data never
+  leaves the corpus tree" posture of the loader layer.
+"""
+
+from __future__ import annotations
+
+from raybrain.privacy.network_guard import NetworkEgressViolation, assert_local
+from raybrain.privacy.path_guard import PathEscapeViolation, assert_under_corpus
+
+__all__ = [
+    "NetworkEgressViolation",
+    "PathEscapeViolation",
+    "assert_local",
+    "assert_under_corpus",
+]
