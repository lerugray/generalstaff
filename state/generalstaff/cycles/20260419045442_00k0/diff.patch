+// on the existing `runCli(["doctor"])` flow covered by doctor.test.ts.
+describe("doctor sanity checks (gs-242)", () => {
+  const FIXTURE = join(tmpdir(), "gs-242-doctor-sanity");
+
+  beforeEach(() => {
