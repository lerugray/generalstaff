   exitCode: number | null;
   durationSeconds: number;
   logPath: string;
+  notFoundHint?: string;
+}
+
+// Shell "command not found" signatures across bash, zsh, Windows cmd,
+// PowerShell, and busybox. Matched case-insensitively against stderr.
+const COMMAND_NOT_FOUND_PATTERNS = [
+  /command not found/i,
+  /is not recognized/i,
+  /cannot find/i,
+];
+
+export function detectCommandNotFound(
+  exitCode: number | null,
+  stderr: string,
+): boolean {
+  if (exitCode === 127) return true;
+  return COMMAND_NOT_FOUND_PATTERNS.some((re) => re.test(stderr));
+}
+
+export function buildNotFoundHint(
+  command: string,
+  projectPath: string,
+): string {
+  const head = command.trim().split(/\s+/)[0] ?? command.trim();
+  return (
+    `Verification command '${command}' not found — ` +
+    `is the tool installed in ${projectPath}? ` +
+    `(Try: cd ${projectPath} && ${head})`
+  );
 }
 
