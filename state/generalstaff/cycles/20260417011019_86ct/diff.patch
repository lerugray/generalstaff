+    super(`Failed to load tasks from ${filePath}: ${reason}`);
+    this.name = "TasksLoadError";
+  }
+}
+
 export async function loadTasks(projectId: string): Promise<GreenfieldTask[]> {
   const path = tasksPath(projectId);
   if (!existsSync(path)) return [];
