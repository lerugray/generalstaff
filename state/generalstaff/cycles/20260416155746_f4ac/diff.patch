+  it("outputs one tab-delimited line per row with no headers", async () => {
+    const rows = [
+      { cycle_id: "cycle-abc123", project: "myproj", outcome: "verified", duration: "2m", sha_range: "aaa..bbb", timestamp: "2026-04-16 12:00:00Z" },
