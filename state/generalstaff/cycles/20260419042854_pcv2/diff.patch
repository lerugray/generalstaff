+      args: args.slice(2),
+      options: {
+        from: { type: "string" },
+        body: { type: "string" },
+        kind: { type: "string" },
+        "session-id": { type: "string" },
+        "task-id": { type: "string" },
+        "cycle-id": { type: "string" },
