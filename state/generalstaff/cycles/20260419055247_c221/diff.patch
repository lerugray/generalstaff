+            console.log(JSON.stringify({}, null, 2));
+          } else {
+            console.log("No projects registered.");
+          }
+          break;
+        }
+        targets = all.map((p) => p.id);
+      }
+      const results: Record<string, { ok: boolean; errors: string[] }> = {};
+      let anyFail = false;
+      for (const id of targets) {
+        try {
+          await loadTasks(id);
