+      if (valValues.project) {
+        if (yamlExists) {
+          const registered = await loadProjects();
+          if (!registered.find((p) => p.id === valValues.project)) {
+            const ids =
+              registered.map((p) => p.id).join(", ") || "(none)";
+            console.error(
+              `Error: project '${valValues.project}' not found. Registered: ${ids}`,
+            );
+            process.exit(1);
