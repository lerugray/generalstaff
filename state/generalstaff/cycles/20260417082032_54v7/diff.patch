+function makeCycleEnd(
+  cycleId: string,
+  timestamp: string,
+  outcome: string,
+  durationSeconds: number,
+  startSha: string,
+  endSha: string,
+): string {
+  return JSON.stringify({
+    timestamp,
+    event: "cycle_end",
+    cycle_id: cycleId,
+    project_id: "recent-proj",
+    data: {
+      outcome,
+      duration_seconds: durationSeconds,
+      start_sha: startSha,
+      end_sha: endSha,
+      reason: "",
+    },
+  });
+}
