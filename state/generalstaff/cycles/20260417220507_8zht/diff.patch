+  describe("stop --status", () => {
+    const STOP_STATUS_DIR = join(import.meta.dir, "fixtures", "stop_status_test");
+
+    beforeEach(() => {
+      mkdirSync(STOP_STATUS_DIR, { recursive: true });
+      mkdirSync(join(STOP_STATUS_DIR, "state"), { recursive: true });
+    });
+
+    afterEach(() => {
+      rmSync(STOP_STATUS_DIR, { recursive: true, force: true });
+    });
+
+    it("reports both absent when no STOP file and no pid file", async () => {
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("STOP file: absent");
+      expect(result.stdout).toContain("Session pid: none recorded");
+      // Confirms it does not create the STOP file as a side effect.
+      expect(result.stdout).not.toContain("present at");
+    });
+
+    it("reports STOP present + pid recorded", async () => {
+      writeFileSync(join(STOP_STATUS_DIR, "STOP"), "");
+      writeFileSync(join(STOP_STATUS_DIR, "state", "session.pid"), "12345");
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("STOP file: present at");
+      expect(result.stdout).toContain("STOP");
+      expect(result.stdout).toContain("Session pid: 12345");
+    });
+
+    it("reports STOP present + no pid", async () => {
+      writeFileSync(join(STOP_STATUS_DIR, "STOP"), "");
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("STOP file: present at");
+      expect(result.stdout).toContain("Session pid: none recorded");
+    });
+
+    it("reports STOP absent + pid recorded", async () => {
+      writeFileSync(join(STOP_STATUS_DIR, "state", "session.pid"), "67890");
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("STOP file: absent");
+      expect(result.stdout).toContain("Session pid: 67890");
+    });
+
+    it("does not create the STOP file as a side effect", async () => {
+      const stopPath = join(STOP_STATUS_DIR, "STOP");
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      // STOP must still be absent on disk after the status check.
+      const { existsSync } = await import("fs");
+      expect(existsSync(stopPath)).toBe(false);
+    });
+
+    it("does not remove the STOP file as a side effect", async () => {
+      const stopPath = join(STOP_STATUS_DIR, "STOP");
+      writeFileSync(stopPath, "");
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      const { existsSync } = await import("fs");
+      expect(existsSync(stopPath)).toBe(true);
+    });
+
+    it("rejects --status combined with --force", async () => {
+      const result = await runCli(["stop", "--status", "--force"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(1);
+      expect(result.stderr).toContain(
+        "--status and --force are mutually exclusive",
+      );
+    });
+
+    it("is advertised in --help output", async () => {
+      const result = await runCli(["--help"]);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("--status");
+      expect(result.stdout).toContain("create/remove nothing");
+    });
+  });
+
