diff --git a/src/register.ts b/src/register.ts
new file mode 100644
index 0000000..945660e
--- /dev/null
+++ b/src/register.ts
@@ -0,0 +1,210 @@
+// GeneralStaff — register command: append a bootstrapped project to
+// projects.yaml after reading state/<id>/tasks.json + hands_off.yaml
+// + project metadata. Confirmation-gated; rejects duplicates and
+// missing-bootstrap cases.
+//
+// Rule 5 keeps projects.yaml in every project's hands_off surface by
+// default, but this command — like `init` — is the tool's own write
+// path to its own config and is therefore an explicit exception. The
+// bot never invokes `register`; only a human operator does.
+
+import { existsSync, readFileSync } from "fs";
+import { readFile, writeFile } from "fs/promises";
+import { join, resolve } from "path";
+import { parse as parseYaml, stringify as stringifyYaml } from "yaml";
+import { createInterface } from "readline";
+import { getRootDir } from "./state";
+import { detectStack, type StackKind } from "./bootstrap";
+
+const PROPOSAL_DIR = ".generalstaff-proposal";
+
+export interface RegisterOptions {
+  projectId: string;
+  targetDir: string;
+  priority?: number;
+  assumeYes?: boolean;
+  prompt?: (question: string) => Promise<boolean>;
+  stack?: StackKind;
+}
+
+export interface RegisterResult {
+  ok: boolean;
+  reason?: string;
+  wrote?: boolean;
+  projectsYamlPath?: string;
+  projectsYamlInHandsOff?: boolean;
+}
+
+async function defaultPrompt(question: string): Promise<boolean> {
+  const rl = createInterface({ input: process.stdin, output: process.stdout });
+  return new Promise<boolean>((resolvePromise) => {
+    rl.question(`${question} [y/N] `, (answer) => {
+      rl.close();
+      resolvePromise(/^y(es)?$/i.test(answer.trim()));
+    });
+  });
+}
+
+function loadHandsOffPatterns(
+  targetDir: string,
+): { source: string; patterns: string[] } | null {
+  const candidates = [
+    join(targetDir, "hands_off.yaml"),
+    join(targetDir, PROPOSAL_DIR, "hands_off.yaml"),
+  ];
+  for (const p of candidates) {
+    if (!existsSync(p)) continue;
+    try {
+      const parsed = parseYaml(readFileSync(p, "utf8")) as
+        | { patterns?: unknown }
+        | null
+        | undefined;
+      if (
+        parsed &&
+        Array.isArray(parsed.patterns) &&
+        parsed.patterns.length > 0
+      ) {
+        return { source: p, patterns: parsed.patterns.map(String) };
+      }
+    } catch {
+      continue;
+    }
+  }
+  return null;
+}
+
+const DEFAULT_DISPATCHER = {
+  state_dir: "./state",
+  fleet_state_file: "./fleet_state.json",
+  stop_file: "./STOP",
+  override_file: "./next_project.txt",
+  picker: "priority_x_staleness",
+  max_cycles_per_project_per_session: 3,
+  log_dir: "./logs",
+  digest_dir: "./digests",
+};
+
+export async function runRegister(
+  opts: RegisterOptions,
+): Promise<RegisterResult> {
+  const { projectId } = opts;
+
+  if (!projectId || !/^[a-z0-9_-]+$/i.test(projectId)) {
+    return {
+      ok: false,
+      reason: `Project id "${projectId}" invalid. Use alphanumerics, dashes, and underscores only.`,
+    };
+  }
+
+  const resolvedTarget = resolve(opts.targetDir);
+  if (!existsSync(resolvedTarget)) {
+    return {
+      ok: false,
+      reason: `Target dir ${resolvedTarget} does not exist.`,
+    };
+  }
+
+  const stateDir = join(resolvedTarget, "state", projectId);
+  const tasksPath = join(stateDir, "tasks.json");
+  if (!existsSync(tasksPath)) {
+    const proposalHint = join(resolvedTarget, PROPOSAL_DIR);
+    return {
+      ok: false,
+      reason:
+        `No tasks.json at ${tasksPath}. ` +
+        `The project has not been bootstrapped yet — run ` +
+        `\`generalstaff bootstrap ${resolvedTarget} "<idea>" --stack=<stack>\` ` +
+        `first (see ${proposalHint}/ for generated scaffolding).`,
+    };
+  }
+
+  const projectsYamlPath = join(getRootDir(), "projects.yaml");
+  type RawYaml = {
+    projects?: Array<Record<string, unknown>>;
+    dispatcher?: Record<string, unknown>;
+  };
+  let existing: RawYaml = { projects: [], dispatcher: {} };
+  if (existsSync(projectsYamlPath)) {
+    try {
+      const parsed = parseYaml(
+        await readFile(projectsYamlPath, "utf8"),
+      ) as RawYaml | null;
+      existing = parsed ?? { projects: [], dispatcher: {} };
+    } catch (e) {
+      return {
+        ok: false,
+        reason: `Failed to parse ${projectsYamlPath}: ${(e as Error).message}`,
+      };
+    }
+    if (!Array.isArray(existing.projects)) existing.projects = [];
+  }
+  const projectsArr = existing.projects ?? [];
+  if (projectsArr.some((p) => p && p.id === projectId)) {
+    return {
+      ok: false,
+      reason: `Project id "${projectId}" is already registered in ${projectsYamlPath}.`,
+    };
+  }
+
+  const handsOff = loadHandsOffPatterns(resolvedTarget);
+  if (!handsOff) {
+    const proposalHint = join(resolvedTarget, PROPOSAL_DIR, "hands_off.yaml");
+    return {
+      ok: false,
+      reason:
+        `No hands_off.yaml found at ${resolvedTarget}/hands_off.yaml or ` +
+        `${proposalHint}. Bootstrap the project first or move ` +
+        `hands_off.yaml from the ${PROPOSAL_DIR}/ staging dir to the project root.`,
+    };
+  }
+
+  const stack = detectStack(resolvedTarget, opts.stack);
+
+  const promptFn = opts.prompt ?? defaultPrompt;
+  const confirmed =
+    opts.assumeYes === true
+      ? true
+      : await promptFn(
+          `Register project "${projectId}" at ${resolvedTarget}?`,
+        );
+  if (!confirmed) {
+    return { ok: false, reason: "Registration cancelled." };
+  }
+
+  const entry: Record<string, unknown> = {
+    id: projectId,
+    path: resolvedTarget,
+    priority: opts.priority ?? 2,
+    engineer_command: stack.engineerCommand,
+    verification_command: stack.verifyCommand,
+    cycle_budget_minutes: 30,
+    work_detection: "tasks_json",
+    concurrency_detection: "worktree",
+    branch: "bot/work",
+    auto_merge: false,
+    hands_off: handsOff.patterns,
+  };
+  projectsArr.push(entry);
+  existing.projects = projectsArr;
+
+  if (!existing.dispatcher || typeof existing.dispatcher !== "object") {
+    existing.dispatcher = { ...DEFAULT_DISPATCHER };
+  }
+
+  await writeFile(
+    projectsYamlPath,
+    stringifyYaml(existing, { lineWidth: 0 }),
+    "utf8",
+  );
+
+  const projectsYamlInHandsOff = handsOff.patterns.some(
+    (p) => p === "projects.yaml" || p === "./projects.yaml",
+  );
+
+  return {
+    ok: true,
+    wrote: true,
+    projectsYamlPath,
+    projectsYamlInHandsOff,
+  };
+}
