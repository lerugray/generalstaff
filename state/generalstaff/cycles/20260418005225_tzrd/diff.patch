diff --git a/tests/register.test.ts b/tests/register.test.ts
new file mode 100644
index 0000000..05862f8
--- /dev/null
+++ b/tests/register.test.ts
@@ -0,0 +1,259 @@
+import { describe, expect, it, beforeEach, afterEach } from "bun:test";
+import { join } from "path";
+import {
+  mkdirSync,
+  rmSync,
+  existsSync,
+  readFileSync,
+  writeFileSync,
+} from "fs";
+import { parse as parseYaml } from "yaml";
+
+const CLI_PATH = join(import.meta.dir, "..", "src", "cli.ts");
+const FIXTURE_ROOT = join(import.meta.dir, "fixtures", "register_test");
+
+interface CliResult {
+  stdout: string;
+  stderr: string;
+  exitCode: number;
+}
+
+async function runCli(
+  args: string[],
+  cwd: string,
+  stdin?: string,
+): Promise<CliResult> {
+  const proc = Bun.spawn(["bun", "run", CLI_PATH, ...args], {
+    stdout: "pipe",
+    stderr: "pipe",
+    stdin: stdin !== undefined ? "pipe" : "ignore",
+    env: { ...process.env },
+    cwd,
+  });
+  if (stdin !== undefined && proc.stdin) {
+    proc.stdin.write(stdin);
+    await proc.stdin.end();
+  }
+  const [stdout, stderr] = await Promise.all([
+    new Response(proc.stdout).text(),
+    new Response(proc.stderr).text(),
+  ]);
+  const exitCode = await proc.exited;
+  return { stdout, stderr, exitCode };
+}
+
+// Set up a target project with the layout `generalstaff bootstrap`
+// would leave behind: state/<id>/tasks.json inside the target dir,
+// plus hands_off.yaml at the target-dir root (moved out of the
+// .generalstaff-proposal/ staging dir, as the bootstrap's
+// README-PROPOSAL.md instructs).
+function seedBootstrappedProject(
+  targetDir: string,
+  projectId: string,
+): void {
+  mkdirSync(join(targetDir, "state", projectId), { recursive: true });
+  writeFileSync(
+    join(targetDir, "state", projectId, "tasks.json"),
+    JSON.stringify(
+      [
+        {
+          id: `${projectId}-001`,
+          title: "seed",
+          status: "pending",
+          priority: 1,
+        },
+      ],
+      null,
+      2,
+    ) + "\n",
+  );
+  writeFileSync(
+    join(targetDir, "hands_off.yaml"),
+    `patterns:\n  - "node_modules/"\n  - "CLAUDE-AUTONOMOUS.md"\n  - "hands_off.yaml"\n`,
+  );
+  // Minimal package.json so detectStack returns bun-plain (predictable
+  // verify/engineer commands in the assertions below).
+  writeFileSync(
+    join(targetDir, "package.json"),
+    JSON.stringify({ name: projectId, devDependencies: { "@types/bun": "latest" } }),
+  );
+}
+
+describe("register command", () => {
+  const HARNESS_DIR = join(FIXTURE_ROOT, "harness");
+  const TARGET_DIR = join(FIXTURE_ROOT, "target");
+
+  beforeEach(() => {
+    mkdirSync(HARNESS_DIR, { recursive: true });
+    mkdirSync(TARGET_DIR, { recursive: true });
+  });
+
+  afterEach(() => {
+    rmSync(FIXTURE_ROOT, { recursive: true, force: true });
+  });
+
+  it("adds a new project to projects.yaml after y confirmation", async () => {
+    seedBootstrappedProject(TARGET_DIR, "gamr");
+
+    const result = await runCli(
+      ["register", "gamr", `--path=${TARGET_DIR}`, "--yes"],
+      HARNESS_DIR,
+    );
+
+    expect(result.exitCode).toBe(0);
+    expect(result.stdout).toContain('Registered project "gamr"');
+
+    const projectsYamlPath = join(HARNESS_DIR, "projects.yaml");
+    expect(existsSync(projectsYamlPath)).toBe(true);
+    const parsed = parseYaml(readFileSync(projectsYamlPath, "utf8")) as {
+      projects: Array<Record<string, unknown>>;
+    };
+    expect(parsed.projects).toHaveLength(1);
+    const entry = parsed.projects[0];
+    expect(entry.id).toBe("gamr");
+    // path is resolved absolute
+    expect(typeof entry.path).toBe("string");
+    expect(entry.hands_off).toEqual([
+      "node_modules/",
+      "CLAUDE-AUTONOMOUS.md",
+      "hands_off.yaml",
+    ]);
+    expect(entry.priority).toBe(2);
+    expect(entry.work_detection).toBe("tasks_json");
+    expect(entry.branch).toBe("bot/work");
+    expect(entry.auto_merge).toBe(false);
+    expect(entry.verification_command).toContain("bun test");
+  });
+
+  it("rejects a duplicate project id", async () => {
+    seedBootstrappedProject(TARGET_DIR, "gamr");
+    writeFileSync(
+      join(HARNESS_DIR, "projects.yaml"),
+      [
+        "projects:",
+        "  - id: gamr",
+        `    path: ${TARGET_DIR}`,
+        "    priority: 2",
+        '    engineer_command: "x"',
+        '    verification_command: "x"',
+        "    cycle_budget_minutes: 30",
+        "    work_detection: tasks_json",
+        "    concurrency_detection: none",
+        "    branch: bot/work",
+        "    auto_merge: false",
+        "    hands_off:",
+        '      - "node_modules/"',
+        "",
+      ].join("\n"),
+    );
+
+    const before = readFileSync(
+      join(HARNESS_DIR, "projects.yaml"),
+      "utf8",
+    );
+
+    const result = await runCli(
+      ["register", "gamr", `--path=${TARGET_DIR}`, "--yes"],
+      HARNESS_DIR,
+    );
+
+    expect(result.exitCode).toBe(1);
+    expect(result.stderr).toContain("already registered");
+
+    // File must be unchanged
+    const after = readFileSync(join(HARNESS_DIR, "projects.yaml"), "utf8");
+    expect(after).toBe(before);
+  });
+
+  it("rejects without confirmation (empty stdin defaults to no)", async () => {
+    seedBootstrappedProject(TARGET_DIR, "gamr");
+
+    const result = await runCli(
+      ["register", "gamr", `--path=${TARGET_DIR}`],
+      HARNESS_DIR,
+      "\n", // empty answer → default "no"
+    );
+
+    expect(result.exitCode).toBe(1);
+    expect(result.stderr).toContain("Registration cancelled");
+    expect(existsSync(join(HARNESS_DIR, "projects.yaml"))).toBe(false);
+  });
+
+  it("rejects when state/<id>/ does not exist in the target dir", async () => {
+    // Target exists but was never bootstrapped — no state/<id>/tasks.json.
+    const result = await runCli(
+      ["register", "gamr", `--path=${TARGET_DIR}`, "--yes"],
+      HARNESS_DIR,
+    );
+
+    expect(result.exitCode).toBe(1);
+    expect(result.stderr).toContain("tasks.json");
+    // Error must point the user at the bootstrap staging dir so they
+    // know the project needs bootstrapping first.
+    expect(result.stderr).toContain(".generalstaff-proposal");
+    expect(existsSync(join(HARNESS_DIR, "projects.yaml"))).toBe(false);
+  });
+
+  it("rejects without --path", async () => {
+    const result = await runCli(["register", "gamr"], HARNESS_DIR);
+    expect(result.exitCode).toBe(1);
+    expect(result.stderr).toContain("--path");
+  });
+
+  it("rejects without project-id", async () => {
+    const result = await runCli(
+      ["register", `--path=${TARGET_DIR}`],
+      HARNESS_DIR,
+    );
+    expect(result.exitCode).toBe(1);
+    expect(result.stderr).toContain("project-id");
+  });
+
+  it("rejects when hands_off.yaml is missing", async () => {
+    // Seed tasks.json but deliberately skip hands_off.yaml.
+    mkdirSync(join(TARGET_DIR, "state", "gamr"), { recursive: true });
+    writeFileSync(
+      join(TARGET_DIR, "state", "gamr", "tasks.json"),
+      JSON.stringify([{ id: "gamr-001", title: "x", status: "pending", priority: 1 }]),
+    );
+
+    const result = await runCli(
+      ["register", "gamr", `--path=${TARGET_DIR}`, "--yes"],
+      HARNESS_DIR,
+    );
+    expect(result.exitCode).toBe(1);
+    expect(result.stderr).toContain("hands_off.yaml");
+    expect(existsSync(join(HARNESS_DIR, "projects.yaml"))).toBe(false);
+  });
+
+  it("falls back to .generalstaff-proposal/hands_off.yaml when root hands_off.yaml is absent", async () => {
+    // Simulate a user who hasn't moved hands_off.yaml out of the
+    // staging dir yet — register should still succeed.
+    mkdirSync(join(TARGET_DIR, "state", "gamr"), { recursive: true });
+    writeFileSync(
+      join(TARGET_DIR, "state", "gamr", "tasks.json"),
+      JSON.stringify([{ id: "gamr-001", title: "x", status: "pending", priority: 1 }]),
+    );
+    mkdirSync(join(TARGET_DIR, ".generalstaff-proposal"), { recursive: true });
+    writeFileSync(
+      join(TARGET_DIR, ".generalstaff-proposal", "hands_off.yaml"),
+      `patterns:\n  - "node_modules/"\n`,
+    );
+
+    const result = await runCli(
+      ["register", "gamr", `--path=${TARGET_DIR}`, "--yes"],
+      HARNESS_DIR,
+    );
+    expect(result.exitCode).toBe(0);
+    const parsed = parseYaml(
+      readFileSync(join(HARNESS_DIR, "projects.yaml"), "utf8"),
+    ) as { projects: Array<Record<string, unknown>> };
+    expect(parsed.projects[0].hands_off).toEqual(["node_modules/"]);
+  });
+
+  it("help text mentions the register command and the hands_off exception", async () => {
+    const result = await runCli(["--help"], HARNESS_DIR);
+    expect(result.stdout).toContain("register");
+    expect(result.stdout).toContain("hands_off");
+  });
+});
