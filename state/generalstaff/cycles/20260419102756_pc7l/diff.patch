+// Shell-level command-not-found signatures across POSIX / cmd / PowerShell.
+const NOT_FOUND_PATTERNS: RegExp[] = [
+  /command not found/i,
+  /is not recognized/i,
+  /cannot find/i,
+];
+
+export function commandHead(command: string): string {
+  const match = command.trim().match(/^(\S+)/);
+  return match ? match[1]! : command.trim();
+}
+
+export function detectCommandNotFound(
+  exitCode: number | null,
+  stderr: string,
+): boolean {
+  if (exitCode === 127) return true;
+  return NOT_FOUND_PATTERNS.some((re) => re.test(stderr));
+}
+
+export function buildNotFoundHint(command: string, projectPath: string): string {
+  const head = commandHead(command);
+  return (
+    `Verification command '${command}' not found — is the tool installed in ` +
+    `${projectPath}? (Try: cd ${projectPath} && ${head})`
+  );
+}
+
 export interface VerificationResult {
   outcome: VerificationOutcome;
   exitCode: number | null;
   durationSeconds: number;
   logPath: string;
+  notFoundHint?: string;
 }
 
