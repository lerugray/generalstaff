+  describe("stop --status (gs-146)", () => {
+    const STOP_STATUS_DIR = join(import.meta.dir, "fixtures", "stop_status_test");
+
+    beforeEach(() => {
+      mkdirSync(join(STOP_STATUS_DIR, "state"), { recursive: true });
+    });
+
+    afterEach(() => {
+      rmSync(STOP_STATUS_DIR, { recursive: true, force: true });
+    });
+
+    it("reports absent STOP file and no pid when neither exists", async () => {
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("STOP file: absent");
+      expect(result.stdout).toContain("Session pid: none recorded");
+      // --status must not create anything
+      expect(existsSync(join(STOP_STATUS_DIR, "STOP"))).toBe(false);
+    });
+
+    it("reports present STOP file with path and recorded pid", async () => {
+      writeFileSync(join(STOP_STATUS_DIR, "STOP"), "halt\n", "utf8");
+      writeFileSync(join(STOP_STATUS_DIR, "state", "session.pid"), "54321", "utf8");
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain(`STOP file: present at ${join(STOP_STATUS_DIR, "STOP")}`);
+      expect(result.stdout).toContain("Session pid: 54321");
+    });
+
+    it("reports present STOP file with no pid on record", async () => {
+      writeFileSync(join(STOP_STATUS_DIR, "STOP"), "halt\n", "utf8");
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("STOP file: present at");
+      expect(result.stdout).toContain("Session pid: none recorded");
+    });
+
+    it("reports absent STOP file even when a pid is recorded", async () => {
+      writeFileSync(join(STOP_STATUS_DIR, "state", "session.pid"), "12345", "utf8");
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("STOP file: absent");
+      expect(result.stdout).toContain("Session pid: 12345");
+      // --status must not remove anything
+      expect(existsSync(join(STOP_STATUS_DIR, "state", "session.pid"))).toBe(true);
+    });
+
+    it("rejects --force and --status together", async () => {
+      const result = await runCli(["stop", "--status", "--force"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(2);
+      expect(result.stderr).toContain("--force and --status are mutually exclusive");
+      // Neither path should have been taken
+      expect(existsSync(join(STOP_STATUS_DIR, "STOP"))).toBe(false);
+    });
+  });
+
