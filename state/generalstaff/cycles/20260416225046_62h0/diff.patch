new file mode 100644
index 0000000..db4565a
--- /dev/null
+++ b/tests/clean.test.ts
@@ -0,0 +1,102 @@
+import { describe, expect, it, beforeEach, afterEach } from "bun:test";
+import { join } from "path";
+import {
+  mkdirSync,
+  rmSync,
+  writeFileSync,
+  utimesSync,
+  existsSync,
+  readdirSync,
+} from "fs";
+import { rotateLogs } from "../src/clean";
+
+const TEST_DIR = join(import.meta.dir, "fixtures", "clean_test");
+const LOGS_DIR = join(TEST_DIR, "logs");
+
+const DAY_MS = 24 * 60 * 60 * 1000;
+
+function writeAged(name: string, ageDays: number, now: number): string {
+  const full = join(LOGS_DIR, name);
+  writeFileSync(full, `log-${name}`, "utf8");
+  const mtimeSec = (now - ageDays * DAY_MS) / 1000;
+  utimesSync(full, mtimeSec, mtimeSec);
+  return full;
+}
+
+describe("rotateLogs", () => {
+  beforeEach(() => {
+    rmSync(TEST_DIR, { recursive: true, force: true });
+    mkdirSync(LOGS_DIR, { recursive: true });
+  });
+
+  afterEach(() => {
+    rmSync(TEST_DIR, { recursive: true, force: true });
+  });
+
+  it("returns 0 when logs dir does not exist", () => {
+    rmSync(LOGS_DIR, { recursive: true, force: true });
+    expect(rotateLogs(LOGS_DIR, 30)).toBe(0);
+  });
+
+  it("returns 0 when no files are older than threshold", () => {
+    const now = Date.now();
+    writeAged("recent.log", 1, now);
+    writeAged("yesterday.log", 5, now);
+
+    expect(rotateLogs(LOGS_DIR, 30, now)).toBe(0);
+    expect(existsSync(join(LOGS_DIR, "recent.log"))).toBe(true);
+    expect(existsSync(join(LOGS_DIR, "yesterday.log"))).toBe(true);
+  });
+
+  it("deletes only files older than the threshold (default 30 days)", () => {
+    const now = Date.now();
+    writeAged("fresh.log", 1, now);
+    writeAged("borderline-young.log", 29, now);
+    writeAged("borderline-old.log", 31, now);
+    writeAged("ancient.log", 90, now);
+
+    const deleted = rotateLogs(LOGS_DIR, 30, now);
+
+    expect(deleted).toBe(2);
+    expect(existsSync(join(LOGS_DIR, "fresh.log"))).toBe(true);
+    expect(existsSync(join(LOGS_DIR, "borderline-young.log"))).toBe(true);
+    expect(existsSync(join(LOGS_DIR, "borderline-old.log"))).toBe(false);
+    expect(existsSync(join(LOGS_DIR, "ancient.log"))).toBe(false);
+  });
+
+  it("respects a custom log-days override", () => {
+    const now = Date.now();
+    writeAged("a.log", 5, now);
+    writeAged("b.log", 8, now);
+    writeAged("c.log", 14, now);
+
+    // With 7-day threshold, only b and c should be deleted
+    const deleted = rotateLogs(LOGS_DIR, 7, now);
+
+    expect(deleted).toBe(2);
+    expect(existsSync(join(LOGS_DIR, "a.log"))).toBe(true);
+    expect(existsSync(join(LOGS_DIR, "b.log"))).toBe(false);
+    expect(existsSync(join(LOGS_DIR, "c.log"))).toBe(false);
+  });
+
+  it("does not descend into subdirectories", () => {
+    const now = Date.now();
+    const sub = join(LOGS_DIR, "subdir");
+    mkdirSync(sub, { recursive: true });
+    const oldFileInSub = join(sub, "old.log");
+    writeFileSync(oldFileInSub, "x", "utf8");
+    const mtimeSec = (now - 100 * DAY_MS) / 1000;
+    utimesSync(oldFileInSub, mtimeSec, mtimeSec);
+
+    const deleted = rotateLogs(LOGS_DIR, 30, now);
+
+    expect(deleted).toBe(0);
+    expect(existsSync(oldFileInSub)).toBe(true);
+    expect(existsSync(sub)).toBe(true);
+  });
+
+  it("handles empty logs directory", () => {
+    expect(readdirSync(LOGS_DIR)).toHaveLength(0);
+    expect(rotateLogs(LOGS_DIR, 30)).toBe(0);
+  });
+});
