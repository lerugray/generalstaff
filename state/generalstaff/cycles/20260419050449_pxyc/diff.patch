+      // Task order preserved.
+      const saved = JSON.parse(raw);
+      expect(saved.map((t: { id: string }) => t.id)).toEqual([
+        "gs-001",
+        "gs-002",
+      ]);
+    });
+
+    it("is a no-op with a friendly message when flag already matches target", async () => {
