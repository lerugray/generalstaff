+++ b/tests/clean.test.ts
@@ -0,0 +1,80 @@
+import { describe, expect, it, beforeEach, afterEach } from "bun:test";
+import { join } from "path";
+import {
+  existsSync,
+  mkdirSync,
+  readdirSync,
+  rmSync,
+  utimesSync,
+  writeFileSync,
+} from "fs";
+import { pruneOldLogs } from "../src/clean";
+
+const TEST_DIR = join(import.meta.dir, "fixtures", "clean_test");
+
+function writeLog(name: string, ageDays: number, now: Date) {
+  const path = join(TEST_DIR, "logs", name);
+  writeFileSync(path, `log content for ${name}\n`);
+  const t = new Date(now.getTime() - ageDays * 24 * 60 * 60 * 1000);
+  utimesSync(path, t, t);
+  return path;
+}
+
+beforeEach(() => {
+  rmSync(TEST_DIR, { recursive: true, force: true });
+  mkdirSync(join(TEST_DIR, "logs"), { recursive: true });
+});
+
+afterEach(() => {
+  rmSync(TEST_DIR, { recursive: true, force: true });
+});
+
+describe("pruneOldLogs", () => {
+  it("returns 0 when the logs directory does not exist", () => {
+    const missing = join(TEST_DIR, "does_not_exist");
+    expect(pruneOldLogs(missing, 30)).toBe(0);
+  });
+
+  it("deletes files older than N days and keeps newer ones (default 30)", () => {
+    const now = new Date("2026-04-16T12:00:00.000Z");
+    writeLog("fresh.log", 1, now);
+    writeLog("edge_below.log", 29, now);
+    writeLog("stale.log", 31, now);
+    writeLog("very_stale.log", 90, now);
+
+    const deleted = pruneOldLogs(join(TEST_DIR, "logs"), 30, now);
+    expect(deleted).toBe(2);
+
+    const remaining = readdirSync(join(TEST_DIR, "logs")).sort();
+    expect(remaining).toEqual(["edge_below.log", "fresh.log"]);
+    expect(existsSync(join(TEST_DIR, "logs", "stale.log"))).toBe(false);
+    expect(existsSync(join(TEST_DIR, "logs", "very_stale.log"))).toBe(false);
+  });
+
+  it("respects a custom day threshold (log-days=7)", () => {
+    const now = new Date("2026-04-16T12:00:00.000Z");
+    writeLog("a.log", 3, now);   // keep
+    writeLog("b.log", 6, now);   // keep (< 7)
+    writeLog("c.log", 8, now);   // delete (> 7)
+    writeLog("d.log", 40, now);  // delete
+
+    const deleted = pruneOldLogs(join(TEST_DIR, "logs"), 7, now);
+    expect(deleted).toBe(2);
+
+    const remaining = readdirSync(join(TEST_DIR, "logs")).sort();
+    expect(remaining).toEqual(["a.log", "b.log"]);
+  });
+
+  it("skips subdirectories inside the logs dir", () => {
+    const now = new Date("2026-04-16T12:00:00.000Z");
+    writeLog("old.log", 60, now);
+    mkdirSync(join(TEST_DIR, "logs", "archive"), { recursive: true });
+    // make the subdir itself appear old — should still be untouched
+    const subOld = new Date(now.getTime() - 365 * 24 * 60 * 60 * 1000);
+    utimesSync(join(TEST_DIR, "logs", "archive"), subOld, subOld);
+
+    const deleted = pruneOldLogs(join(TEST_DIR, "logs"), 30, now);
+    expect(deleted).toBe(1);
+    expect(existsSync(join(TEST_DIR, "logs", "archive"))).toBe(true);
+  });
+});
