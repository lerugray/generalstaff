+  describe("stop --status", () => {
+    const STOP_STATUS_DIR = join(import.meta.dir, "fixtures", "stop_status_test");
+
+    beforeEach(() => {
+      mkdirSync(join(STOP_STATUS_DIR, "state"), { recursive: true });
+    });
+
+    afterEach(() => {
+      rmSync(STOP_STATUS_DIR, { recursive: true, force: true });
+    });
+
+    it("reports absent STOP file and no recorded pid", async () => {
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("STOP file: absent");
+      expect(result.stdout).toContain("Session pid: none recorded");
+    });
+
+    it("reports STOP file present at path when file exists", async () => {
+      writeFileSync(join(STOP_STATUS_DIR, "STOP"), "");
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("STOP file: present at ");
+      expect(result.stdout).toContain(join(STOP_STATUS_DIR, "STOP"));
+      expect(result.stdout).toContain("Session pid: none recorded");
+    });
+
+    it("reports recorded pid when session.pid file exists", async () => {
+      writeFileSync(join(STOP_STATUS_DIR, "state", "session.pid"), "4242");
+      const result = await runCli(["stop", "--status"], STOP_STATUS_DIR);
+      expect(result.exitCode).toBe(0);
+      expect(result.stdout).toContain("STOP file: absent");
+      expect(result.stdout).toContain("Session pid: 4242");
+    });
+
+    it("reports both STOP present and pid when both exist", async () => {
+      writeFileSync(join(STOP_STATUS_DIR, "STOP"), "");
