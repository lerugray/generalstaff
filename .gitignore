# Real projects.yaml may contain absolute paths Ray prefers private
projects.yaml
# Tracked fixture registry — synthetic paths, safe to commit (gs-241).
!tests/fixtures/view_integration/projects.yaml

# Logs from dispatcher runs
logs/
*.log

# Fleet state — committed or not depending on whether GeneralStaff itself
# becomes a git repo. For now, treat as private working state.
fleet_state.json

# Per-cycle digest files
digests/

# Override + kill-switch files (transient)
next_project.txt
STOP

# Transient pid file — written at session start by scripts/run_session.bat,
# cleaned at session end. Tracking it causes `D state/session.pid` residue
# that blocks the next launch's clean-tree preflight (gs-236).
state/session.pid

# Per-cycle detail artifacts (reviewer-prompt.txt, reviewer-response.txt,
# diff.patch, etc.) — contain the FULL diff text which could embed a
# secret if the engineer accidentally committed a .env or similar. The
# canonical open audit log (Hard Rule 9) is state/<id>/PROGRESS.jsonl,
# which records verdicts, reasons, hands_off_violations, and diff_length
# — not the raw diff body. Pre-launch security audit 2026-04-19 (MEDIUM)
# flagged committing the per-cycle files as a secret-exposure surface;
# PROGRESS.jsonl alone is enough for the "count the rejections yourself"
# audit story, and per-cycle files remain on disk for local inspection.
state/*/cycles/
state/_fleet/cycles/

# Maintainer-private project state (per-machine). For projects where
# tasks.json / MISSION.md / PROGRESS.jsonl contain IP-sensitive or
# personally-identifying content that shouldn't land on the public repo.
# The canonical copy lives in the sibling private repo at
# `.claude/local/state/<id>/` (see `.claude/local/CLAUDE.local.md`
# §"Private-state projects" for the convention + sync procedure).
# Contributors on a fresh public clone simply won't see these dirs;
# the CLI falls back to empty tasks.json / missing MISSION.md
# gracefully for projects that aren't locally populated.
state/retrogaze/
state/devforge/
state/gamr/
state/raybrain/
state/zero-page/
state/veridian-contraption/
state/conflict-simulations/
state/amfiog/

# Bun / Node
node_modules/
bun.lock
dist/

# Test fixtures (generated by bun test)
# Ignore all direct children of tests/fixtures/ (each test owns its own
# subdir and nukes it on cleanup), but re-include the reviewer_calibration
# subdir — those files (gs-156) are tracked data, not generated.
tests/fixtures/*
!tests/fixtures/reviewer_calibration/
!tests/fixtures/provider_config_malformed/
!tests/fixtures/fake_project/
!tests/fixtures/view_integration/

# Bot worktree (created by scripts/run_bot.sh, cleaned on exit)
.bot-worktree/

# Temporary
*.tmp
*.swp
.DS_Store

# Python bytecode (in case any helpers get written in Python)
__pycache__/
*.pyc

# Editor
.vscode/
.idea/

# Claude Code per-machine state (allow-lists, scheduled-task locks, etc.)
# Shared settings live in .claude/settings.json, which IS tracked.
# Everything else under .claude/ is per-machine / transient — including
# settings.local.json, scheduled_tasks.lock, and any future harness files.
.claude/*
!.claude/settings.json

# Obsidian per-machine vault state
# Shared settings would be in .obsidian/app.json etc., which can be tracked
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspaces.json

# lean-ctx per-machine config (regenerated by `lean-ctx init --agent claude`).
# Each machine/user runs its own init and gets its own AGENTS.md, LEAN-CTX.md,
# and .cursorrules — not checked in so the OSS repo stays tool-agnostic and
# there's no per-user drift.
AGENTS.md
LEAN-CTX.md
.cursorrules
.aider*
