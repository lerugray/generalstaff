# GeneralStaff project registry — example schema (Phase 1)
#
# Real registry lives at projects.yaml (gitignored — contains absolute
# paths). This file is the schema reference.
#
# Adding a project is a ceremony, NOT a casual edit:
#   1. Create state/<project_id>/MISSION.md in GeneralStaff
#   2. Define engineer_command (what launches the bot)
#   3. Define verification_command (independent test gate)
#   4. Define hands_off list (mandatory, non-empty)
#
# A project without all 4 is a slop machine. Don't register it.
#
# NOTE: GeneralStaff state lives in GeneralStaff's own directory
# under state/<project_id>/. Nothing is written to the managed
# project's working tree by the dispatcher. See PHASE-1-RESOLUTIONS
# §Q5 for rationale.
#
# -------------------------------------------------------------------
# Key environment variables (set in your shell, a .env loader, or the
# launcher script — NOT committed here).
# -------------------------------------------------------------------
#
#   GENERALSTAFF_REVIEWER_PROVIDER
#       Which provider runs the verification-gate reviewer. One of
#       `claude` (uses `claude -p` and your Claude subscription
#       quota), `openrouter` (paid per-token, ~$0.02/session on
#       Qwen3 Coder), or `ollama` (local, free, offline). Default:
#       `claude`. For unattended / high-volume runs, prefer
#       `openrouter` to keep pressure off your Claude quota.
#
#   GENERALSTAFF_REVIEWER_MODEL
#       Optional model override. Only meaningful when the provider
#       exposes a model knob (e.g. `qwen/qwen3-coder-plus` on
#       openrouter, `qwen3:8b` on ollama). Each provider picks a
#       sensible default when unset.
#
#   GENERALSTAFF_REVIEWER_FALLBACK_PROVIDER
#       Optional single-shot fallback. If the primary returns a
#       `[REVIEWER ERROR]`, the reviewer retries once using this
#       provider. Skipped when unset or equal to the primary.
#
#   OPENROUTER_API_KEY
#       Required when the primary or fallback provider is
#       `openrouter`. No default; if unset at launch, every cycle
#       fail-safes to `verification_failed` (by design — better a
#       loud skip than a silent pass).
#
#   OLLAMA_HOST
#       Optional. Defaults to `http://localhost:11434`. Used by the
#       ollama reviewer and its pre-flight reachability check.
#
#   GENERALSTAFF_REVIEWER_CONCURRENCY_<PROVIDER>
#       Integer, optional. Overrides the per-provider semaphore the
#       parallel session loop uses. Defaults: claude=∞, openrouter=2,
#       ollama=1. Raise on a paid tier (e.g. `=8` on OpenRouter);
#       lower to throttle. Only binds when `max_parallel_slots > 1`.
#
# Hard Rule 8 (BYOK): every credential above comes from your own
# environment. Nothing is shipped, nothing is hosted on your behalf.

projects:
  - id: catalogdna
    path: C:/Users/rweis/OneDrive/Documents/catalogdna
    priority: 1                              # 1 = highest, 5 = lowest
    engineer_command: "bash run_bot.sh ${cycle_budget_minutes}"
    verification_command: >-
      PYTHONPATH=src .venv/Scripts/python -m pytest tests/ -q
      --ignore=tests/test_property.py --ignore=tests/test_tui.py
      && PYTHONPATH=src .venv/Scripts/python -m ruff check src/ tests/
    cycle_budget_minutes: 60                 # hard timeout per cycle
    work_detection: catalogdna_bot_tasks     # parse bot_tasks.md P0-P3
    concurrency_detection: catalogdna        # 3-signal check (worktree, status, heartbeat)
    branch: bot/work
    auto_merge: false                        # MUST be false until 5 clean cycles
    hands_off:
      - src/catalogdna/interpret/            # IP boundary — proprietary
      - CLAUDE.md                            # project conventions
      - CLAUDE-AUTONOMOUS.md                 # bot instructions
      - .claude/                             # claude code config
      - run_bot*.sh                          # bot launcher scripts
      - run_bot*.bat                         # bot launcher scripts
      - bot_tasks.md                         # bot task list (read+mark only)
      - scripts/bot_heartbeat.sh             # infra script
      - scripts/chrome_review*.sh            # chrome review loop
      - scripts/worktree_venv.py             # worktree bootstrap
    notes: |
      Cornerstone project. Has the most mature bot infra.
      GeneralStaff wraps catalogdna's existing run_bot.sh — it
      does NOT replace it. State lives in state/catalogdna/
      inside GeneralStaff's repo.

  - id: retrogaze-experimental
    path: C:/Users/rweis/OneDrive/Documents/Retrogaze-experimental
    priority: 2
    engineer_command: "<TBD — Phase 3>"
    verification_command: "<TBD — needs test suite before registering>"
    cycle_budget_minutes: 45
    work_detection: tasks_json               # default: GeneralStaff manages tasks
    concurrency_detection: none              # default: no bot infra yet
    branch: bot/work
    auto_merge: false
    hands_off:
      - "<TBD — needs hands_off list before registering>"
    notes: |
      PLACEHOLDER — not registered yet. Pipeline work and sprite
      generation tests are bot-friendly. Marketing / ideation is
      OFF LIMITS per Hard Rule #1.

  - id: sandkasten
    path: C:/Users/rweis/OneDrive/Documents/Sandkasten
    priority: 3
    engineer_command: "<TBD>"
    verification_command: "<TBD>"
    cycle_budget_minutes: 45
    work_detection: tasks_json
    concurrency_detection: none
    branch: bot/work
    auto_merge: false
    hands_off:
      - "<TBD>"
    notes: |
      PLACEHOLDER — not registered yet. Bot work scoped to
      NON-GAME-LOGIC only (UI, scaffolding, save/load, tests).
      Game rules / wargame logic is OFF LIMITS.

# -------------------------------------------------------------------
# Dispatcher-level config
# -------------------------------------------------------------------

dispatcher:
  state_dir: ./state                         # per-project state (NEVER in managed projects)
  fleet_state_file: ./fleet_state.json
  stop_file: ./STOP                          # kill switch
  override_file: ./next_project.txt          # picker override
  picker: priority_x_staleness
  max_cycles_per_project_per_session: 3      # Q1: chaining cap
  log_dir: ./logs
  digest_dir: ./digests

  # -----------------------------------------------------------------
  # Parallel mode — Phase 4 opt-in (gs-186)
  # -----------------------------------------------------------------
  #
  # Run N cycles in parallel per round. Default 1 preserves the
  # sequential dispatcher from Phases 1-3 (chaining, STOP mid-cycle,
  # no concurrent reviewer calls) bit-for-bit.
  #
  # When to turn it on: your fleet has 2+ projects with real
  # backlogs each AND session wall-clock is the bottleneck. Round-
  # based strict-wait — all slots in a round finish before the next
  # round starts. Chaining is disabled in parallel mode (each round
  # picks fresh projects); an empty-queue project gets skipped
  # rather than padded into an idle slot (gs-232).
  #
  # Cost: parallel N roughly multiplies reviewer-step API spend by
  # N on external providers. Hard Rule 8 (BYOK) applies — the cost
  # shows up on your bill. Per-provider semaphores (default
  # claude=∞, openrouter=2, ollama=1) prevent reviewer stampedes;
  # tune via GENERALSTAFF_REVIEWER_CONCURRENCY_<PROVIDER>.
  #
  # Recommended: start at 2 on a 3-project fleet, watch
  # `slot_idle_seconds` in session_complete + `status --sessions`,
  # bump only if utilization stays high. Drop back to 1 if
  # reviewer-spend or UX feedback warrants.
  max_parallel_slots: 1
